# Copia in `.env` nella root del monorepo (gitignored) per `docker compose build`.
# Valori allineati a `storefront/.env` e `vendor-panel/.env` sul server.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_ALGOLIA_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
VITE_PUBLISHABLE_API_KEY=
# Storefront build: mantieni la home “Coming Soon” su tramelle.com fino al go-live pubblico.
NEXT_PUBLIC_COMING_SOON_HOME=true

# Opzionale — solo server: PAT GitHub (`repo`) per `scripts/git-push-with-token-from-env.sh` (non usato dalle app).
GITHUB_TOKEN=
