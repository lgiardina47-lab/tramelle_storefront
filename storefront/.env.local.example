# Sviluppo: `next dev` carica `.env.development` poi questo file (`.env.local` vince sulle chiavi duplicate).
# Build produzione: committato `.env.production` (api/storefront/vendor/cdn reali); chiavi segrete solo in CI o `.env.production.local`.
#
# Sviluppo locale (backend: yarn dev su porta 9000): usa sempre l'API Medusa, non l'URL dello shop.
MEDUSA_BACKEND_URL=http://127.0.0.1:9000
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://127.0.0.1:9000
# Base pubblica CDN partner (cover_/logo_); default https://cdn.tramelle.com se omesso
# NEXT_PUBLIC_TRAMELLE_CDN_PUBLIC_BASE=https://cdn.tramelle.com
#
# Cloudflare Images: stessi hash/variant del backend; espandono `cfimg:<id>` su seller.photo / metadata.
# Obbligatorio per le card produttori nel browser (solo NEXT_PUBLIC_* è incluso nel bundle client).
# NEXT_PUBLIC_CLOUDFLARE_IMAGES_ACCOUNT_HASH=
# Default = variante CF "tramelle" (URL corti, risoluzione sorgente fino a 12000px, AVIF/WebP). Override: …VARIANT=public
# Opzionale: stesso valore senza NEXT_PUBLIC per codice solo server / build
# CLOUDFLARE_IMAGES_ACCOUNT_HASH=
# CLOUDFLARE_IMAGES_VARIANT=… (solo se serve stesso valore lato server)
# Host delivery Images (Custom Domain), es. media.tramelle.com
# NEXT_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_HOST=media.tramelle.com
# Su server Hetzner / produzione: https://api.tuodominio.com (deve rispondere con JSON su /store/regions, non HTML)
# MEDUSA_BACKEND_URL=https://api.tramelle.com
# NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.tramelle.com
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_dopo_seed
# Public URL for canonicals, OG, JSON-LD. Default in code is https://tramelle.com if unset (localhost dev still shows Tramelle in metadata).
NEXT_PUBLIC_BASE_URL=https://tramelle.com
# Omit or leave false: search engines are blocked (robots.txt + noindex). Set to true only for public SEO.
# NEXT_PUBLIC_ALLOW_SEARCH_INDEXING=true
NEXT_PUBLIC_DEFAULT_REGION=it
# Publishable Stripe (stesso account della STRIPE_SECRET_API_KEY nel backend)
NEXT_PUBLIC_STRIPE_KEY=
REVALIDATE_SECRET=supersecret
NEXT_PUBLIC_SITE_NAME=Tramelle Source Gourmet
NEXT_PUBLIC_SITE_DESCRIPTION=Tramelle Source Gourmet: specialità alimentari, produttori e gusti selezionati per te.
# Listing / ricerca prodotti: usa `POST /store/products/search` sul Medusa (plugin Algolia). Le chiavi sono nel backend.
# Non servono qui per la UI. Opzionale: solo per `node scripts/push-algolia-index-settings.mjs` — stesso Application ID del backend.
# NEXT_PUBLIC_ALGOLIA_ID=
# Per disabilitare la ricerca Algolia e usare solo `GET /store/products` (griglia statica): `NEXT_PUBLIC_DISABLE_ALGOLIA_LISTING=true`
# true = nasconde filtri prezzo/taglia/colore nella listing (tema sneakers demo)
# false = mostra sidebar facet nella listing Algolia (prezzo + facet da indice)
NEXT_PUBLIC_HIDE_LISTING_FILTERS=false
# true = mostra anche facet “Category” (categories.name) nella sidebar
# NEXT_PUBLIC_LISTING_CATEGORY_FACET=true
# true = anche facet colore / taglia / condizione (demo sneakers)
# NEXT_PUBLIC_LISTING_VARIANT_FACETS=true

# B2B: id gruppo Medusa (es. cg_...) + Secret API Key admin — assegnazione immediata al gruppo dopo signup professionista (server-only).
# MEDUSA_ADMIN_API_KEY=
# TRAMELLE_B2B_PRO_GROUP_ID=
# Se il gruppo non si chiama esattamente B2B_Pro, allinea nome pubblico (deve combaciare con /store/customers/me groups).
# NEXT_PUBLIC_TRAMELLE_B2B_PRO_GROUP_NAME=B2B_Pro
# Alternativa: elenco id gruppi wholesale separati da virgola (senza nome).
# NEXT_PUBLIC_TRAMELLE_WHOLESALE_GROUP_IDS=
