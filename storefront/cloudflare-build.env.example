# Variabili da impostare in Cloudflare → Workers → tramelle-storefront →
# Impostazioni → Variabili e segreti (ambiente Build / Produzione).
# Copia le coppie chiave=valore nella dashboard. Valori reali: dal tuo .env / .env.production (non committare segreti).
#
# OBBLIGATORIE per scheda produttore / prodotti / immagini in produzione:
# - NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY (pk_… dal backend; senza → pagina vuota o “Nessun prodotto” / errori fetch)
# - NEXT_PUBLIC_CLOUDFLARE_IMAGES_ACCOUNT_HASH (+ DELIVERY_HOST se usi dominio custom) per espandere cfimg lato client ove serve
#
# Node.js (Workers Builds): vedi https://developers.cloudflare.com/workers/ci-cd/builds/build-image/
# In alternativa al variabile, nella root build c’è `.nvmrc` (20).
NODE_VERSION=20
#
# Obbligatorie per una build sensata:
NODE_ENV=production
MEDUSA_BACKEND_URL=https://api.tramelle.com
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.tramelle.com
NEXT_PUBLIC_BASE_URL=https://tramelle.com
NEXT_PUBLIC_DEFAULT_REGION=it
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_sostituisci_dopo_seed
NEXT_PUBLIC_SITE_NAME=Tramelle Source Gourmet
NEXT_PUBLIC_SITE_DESCRIPTION=Tramelle Source Gourmet: specialità alimentari, produttori e gusti selezionati per te.
#
# Opzionale: segmento URL /en/ filtra `supported_countries`; se l'indice non ha `gb`, lascia vuoto (= default `it` in codice).
# NEXT_PUBLIC_EN_SEARCH_SUPPORTED_COUNTRY=it
#
# Opzionali (allinea al backend / Stripe):
NEXT_PUBLIC_TRAMELLE_CDN_PUBLIC_BASE=https://cdn.tramelle.com
# Cloudflare Images (stessi valori di CLOUDFLARE_IMAGES_* nel backend; solo hash + variant, no token)
NEXT_PUBLIC_CLOUDFLARE_IMAGES_ACCOUNT_HASH=
# Omesso = default: variante tramelle (full-res sorgente fino a 12000px, AVIF/WebP). Override: public, ecc.
# NEXT_PUBLIC_CLOUDFLARE_IMAGES_VARIANT=tramelle
# Card directory / home featured: thumbnail delivery (default public). Stesso account; variante nominata in dashboard CF.
# NEXT_PUBLIC_CLOUDFLARE_IMAGES_VARIANT_CARD=public
#
# Autosize PDP / card (flexible `w=` nel path + srcset): abilitare “Flexible variants” su Images → Delivery, poi:
NEXT_PUBLIC_CLOUDFLARE_IMAGES_FLEXIBLE_VARIANTS=1
# NEXT_PUBLIC_CLOUDFLARE_IMAGES_CARD_WIDTHS=400,640,960,1280
# Delivery host: es. media.tramelle.com (SEO / first-party). Omesso → imagedelivery.net.
# Cloudflare risponde AVIF/WebP in base al browser (variante nominata, es. tramelle).
NEXT_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_HOST=media.tramelle.com
# Opzionale: strip partner-{handle}- (default off = id CF come in upload). Attiva: NEXT_PUBLIC_TRAMELLE_CFIMG_STRIP_PARTNER_PREFIX=1
NEXT_PUBLIC_VENDOR_URL=https://vendor.tramelle.com
NEXT_PUBLIC_STRIPE_KEY=
NEXT_PUBLIC_HIDE_LISTING_FILTERS=false
REVALIDATE_SECRET=sostituisci_segreta
# NEXT_PUBLIC_ALLOW_SEARCH_INDEXING=true
