# Variabili da impostare in Cloudflare → Workers → tramelle-storefront →
# Impostazioni → Variabili e segreti (ambiente Build / Produzione).
# Copia le coppie chiave=valore nella dashboard. Valori reali: dal tuo .env / .env.production (non committare segreti).
#
# Obbligatorie per una build sensata:
NODE_ENV=production
MEDUSA_BACKEND_URL=https://api.tramelle.com
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.tramelle.com
NEXT_PUBLIC_BASE_URL=https://tramelle.com
NEXT_PUBLIC_DEFAULT_REGION=it
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_sostituisci_dopo_seed
NEXT_PUBLIC_SITE_NAME=Tramelle - Gourmet Marketplace
NEXT_PUBLIC_SITE_DESCRIPTION=Tramelle — il marketplace gourmet: specialità alimentari e produttori selezionati.
NEXT_PUBLIC_COMING_SOON_HOME=true
NEXT_PUBLIC_COMING_SOON_DEV_PREVIEW=false
#
# Opzionali (allinea al backend / Stripe / Algolia):
NEXT_PUBLIC_TRAMELLE_CDN_PUBLIC_BASE=https://cdn.tramelle.com
NEXT_PUBLIC_VENDOR_URL=https://vendor.tramelle.com
NEXT_PUBLIC_STRIPE_KEY=
NEXT_PUBLIC_ALGOLIA_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
NEXT_PUBLIC_HIDE_LISTING_FILTERS=false
REVALIDATE_SECRET=sostituisci_segreta
# NEXT_PUBLIC_ALLOW_SEARCH_INDEXING=true
