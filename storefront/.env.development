# Solo `next dev`. Precedenza: `.env.development.local` > `.env.local` > questo file > `.env`
#
# HMR: vedi `next.config.ts` (polling webpack in dev; disattiva con NEXT_DEV_POLLING_OFF=true se non serve).
#
# URL API (produzione): definiti qui nel repo — non chiedere all’utente di “sistemare le env” per il menu.
# Chiavi segrete / pk: solo in `.env` (gitignored), da `.env.local.example`.
#
# Per forzare Medusa in Docker su :9000: `.env.development.local` con
#   MEDUSA_BACKEND_URL=http://127.0.0.1:9000
#   NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://127.0.0.1:9000

MEDUSA_BACKEND_URL=https://api.tramelle.com
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.tramelle.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_TRAMELLE_CDN_PUBLIC_BASE=https://cdn.tramelle.com
NEXT_PUBLIC_VENDOR_URL=http://127.0.0.1:5173

NEXT_PUBLIC_DEFAULT_REGION=it
NEXT_PUBLIC_HIDE_LISTING_FILTERS=false
NEXT_PUBLIC_COMING_SOON_HOME=false
NEXT_PUBLIC_COMING_SOON_DEV_PREVIEW=false

# Next 15 HMR: WebSocket consentito anche aprendo http://<IP>:3000 (oltre localhost).
NEXT_DEV_ALLOWED_ORIGINS=148.251.182.115
