# Nuovo database PostgreSQL dedicato a Mercur (consigliato: nuovo progetto Supabase vuoto).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

REDIS_URL=redis://127.0.0.1:6379

STORE_CORS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_CORS=http://localhost:9000,http://localhost:7000
VENDOR_CORS=http://localhost:5173
AUTH_CORS=http://localhost:9000,http://localhost:7000,http://localhost:5173,http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:7000,http://127.0.0.1:5173

# Mercur (@mercurjs/framework): link nelle email (reset password, inviti vendor).
# Obbligatorio in produzione se admin e API sono su host diversi.
# ADMIN_PANEL_URL — pannello admin Vite (es. https://manage.example.com). Se assente, il reset admin usa BACKEND_URL + /app/reset-password.
# VENDOR_PANEL_URL — pannello vendor (default http://localhost:5173).
# STOREFRONT_URL — storefront B2C (reset password clienti).
# BACKEND_URL — API Medusa (default http://localhost:9000).
ADMIN_PANEL_URL=
VENDOR_PANEL_URL=
STOREFRONT_URL=
BACKEND_URL=

# Tutte le risposte API includono X-Robots-Tag: noindex, nofollow (src/api/middlewares.ts).

JWT_SECRET=change-me
COOKIE_SECRET=change-me

# --- Algolia (opzionale) ---
# Backend: stesso "Application ID" del progetto Algolia + Admin API Key (indicizzazione prodoti/review).
# Lasciare vuoto disattiva il plugin @mercurjs/algolia (lo storefront usa comunque il catalogo senza InstantSearch).
# Storefront: NEXT_PUBLIC_ALGOLIA_ID + NEXT_PUBLIC_ALGOLIA_SEARCH_KEY (Search-Only key). Importare storefront/algolia-config.json nella dashboard Algolia.
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=

# --- Stripe (obbligatorio per avviare Mercur b2c-core: modulo payout usa questa chiave) ---
# Segreta solo nel backend. Nel storefront impostare NEXT_PUBLIC_STRIPE_KEY = publishable key dello STESSO account (Dashboard → Developers → API keys).
# Per Connect: endpoint webhook e STRIPE_CONNECTED_ACCOUNTS_WEBHOOK_SECRET dalla dashboard Stripe.
STRIPE_SECRET_API_KEY=
STRIPE_CONNECTED_ACCOUNTS_WEBHOOK_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Traduzioni vendor (DeepL). Chiave da https://www.deepl.com/pro-api — suffisso :fx = piano gratuito.
# DEEPL_AUTH_KEY=

VITE_TALK_JS_APP_ID=
VITE_TALK_JS_SECRET_API_KEY=

# SSH verso il server Hetzner da Codespace (scripts/vps.sh): password solo in backend/.env locale, non in git.
# VPS_SSH_HOST=   # nome variabile storico = host SSH del server
# VPS_SSH_USER=root
# PASSWORD_SSH=

# Cursor: MCP Supabase hosted — metti il token in backend/.env (NON qui, questo file va in git)
# SUPABASE_ACCESS_TOKEN=

# --- Registrazione B2B (Tramelle) ---
# Nome del customer group Medusa per i professionisti (subscriber + script ensure-b2b-pro-customer-group).
# TRAMELLE_B2B_PRO_GROUP_NAME=B2B_Pro
